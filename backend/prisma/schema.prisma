generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String              @id @default(uuid())
  name          String
  createdAt     DateTime            @default(now())
  auditLogs     AuditLog[]
  comments      Comment[]
  history       HistoryItem[]
  notifications Notification[]
  projects      Project[]
  teamMembers        ProjectTeamMember[]
  scores             ScoreEntry[]
  users              User[]
  checklistTemplates ChecklistTemplate[]
  disciplineSnapshots DisciplineSnapshot[]
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  target     String
  actorId    String
  actorEmail String?
  timestamp  DateTime @default(now())
  metadata   Json?
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([timestamp])
}

model AuditOutbox {
  id         String   @id @default(uuid())
  action     String
  target     String
  actorId    String
  actorEmail String?
  tenantId   String
  metadata   Json?
  createdAt  DateTime @default(now())
}

model User {
  id               String               @id @default(uuid())
  name             String
  username         String?              @unique
  email            String               @unique
  password         String
  role             UserRole
  avatar           String?
  tenantId         String
  isActive         Boolean              @default(true)
  lastRevocationAt DateTime?
  comments         Comment[]
  notifications    Notification[]
  resetTokens      PasswordResetToken[]
  projectsDesigned Project[]            @relation("AssignedDesigner")
  projectsManaged  Project[]            @relation("AssignedDevManager")
  projectsQA       Project[]            @relation("AssignedQA")
  scores           ScoreEntry[]
  disciplineSnapshots DisciplineSnapshot[]
  tenant           Tenant               @relation(fields: [tenantId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  tokenHash String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
}

model Project {
  id                   String              @id @default(uuid())
  name                 String
  clientName           String
  scope                String
  priority             Priority
  stage                ProjectStage
  overallDeadline      DateTime
  currentDeadline      DateTime?
  tenantId             String
  assignedDesignerId   String?
  assignedDevManagerId String?
  assignedQAId         String?
  designChecklist      Json[]
  devChecklist         Json[]
  qaChecklist          Json[]
  finalChecklist        Json[]
  clientReviewChecklist Json[]
  clientUatChecklist    Json[]
  deploymentChecklist   Json[]
  isDelayed             Boolean             @default(false)
  qaFailCount          Int                 @default(0)
  createdAt            DateTime            @default(now())
  completedAt          DateTime?
  enteredStageAt       DateTime?
  updatedAt            DateTime            @updatedAt
  version              Int                 @default(1)
  healthAtCompletion   Float?
  actualOutcome        String?             // ON_TIME | DELAYED | ESCALATED
  comments             Comment[]
  history              HistoryItem[]
  healthSnapshots      ProjectHealthSnapshot[]
  assignedDesigner     User?               @relation("AssignedDesigner", fields: [assignedDesignerId], references: [id])
  assignedDevManager   User?               @relation("AssignedDevManager", fields: [assignedDevManagerId], references: [id])
  assignedQA           User?               @relation("AssignedQA", fields: [assignedQAId], references: [id])
  tenant               Tenant              @relation(fields: [tenantId], references: [id])
  teamMembers          ProjectTeamMember[]
  scores               ScoreEntry[]

  @@index([tenantId])
  @@index([assignedDevManagerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, stage])
  @@index([tenantId, completedAt])
}

model ChecklistTemplate {
  id           String        @id @default(uuid())
  tenantId     String
  stage        ProjectStage
  name         String
  description  String?
  isDefault    Boolean       @default(false)

  version      Int           @default(1)
  isArchived   Boolean       @default(false)

  items        Json          

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId, stage])
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  timestamp DateTime @default(now())
  userId    String
  projectId String
  tenantId  String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model HistoryItem {
  id                String       @id @default(uuid())
  stage                ProjectStage
  toStage              ProjectStage?
  action               String
  timestamp            DateTime     @default(now())
  userId               String
  performedByUserId    String?
  performedByRole      UserRole?
  revertReasonCategory RevertReasonCategory?
  revertReasonNote     String?
  rejectionSnapshot    Json?
  checklistCompletionRate Float?
  projectId         String
  tenantId          String
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant            Tenant       @relation(fields: [tenantId], references: [id])

  @@index([projectId, timestamp])
  @@index([tenantId, stage])
}

model DisciplineSnapshot {
  id              String   @id @default(uuid())
  tenantId        String
  userId          String
  snapshotDate    DateTime @db.Date
  disciplineIndex Float

  qaDomainScore        Float
  reworkDomainScore     Float
  checklistDomainScore  Float
  deadlineDomainScore   Float
  velocityDomainScore   Float

  qaFirstPassCount      Int     @default(0)
  qaRejectCount         Int     @default(0)
  revertCount           Int     @default(0)
  highSevRevertCount    Int     @default(0)
  checklistAvgRate      Float   @default(0)
  onTimeRate            Float   @default(0)
  avgDelayDays          Float   @default(0)
  avgStageDays          Float   @default(0)
  tenantAvgStageDays    Float   @default(0)
  tenantAvgReverts      Float   @default(0)

  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId, snapshotDate])
  @@index([tenantId, userId])
}

model ScoreEntry {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  points    Int
  reason    String
  projectId String
  userId    String
  tenantId  String
  project   Project  @relation(fields: [projectId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@index([tenantId, date])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  timestamp DateTime @default(now())
  userId    String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([tenantId, timestamp])
}

model ProjectTeamMember {
  id        String       @id @default(uuid())
  projectId String
  tenantId  String
  leadRole  TeamLeadRole
  name      String
  roleTitle String
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant    Tenant       @relation(fields: [tenantId], references: [id])

  @@index([projectId])
  @@index([tenantId])
  @@index([projectId, leadRole])
}

enum UserRole {
  ADMIN
  DESIGNER
  DEV_MANAGER
  QA_ENGINEER
}

enum ProjectStage {
  DISCOVERY
  DESIGN
  CLIENT_REVIEW
  DEVELOPMENT
  INTERNAL_QA
  INTERNAL_APPROVAL
  CLIENT_UAT
  DEPLOYMENT
  COMPLETED
}

enum RevertReasonCategory {
  DESIGN_CLARIFICATION
  DEV_IMPLEMENTATION_BUG
  QA_MISS
  CLIENT_CHANGE_REQUEST
  SCOPE_EXPANSION
  PERFORMANCE_ISSUE
  CONTENT_MISSING
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TeamLeadRole {
  DESIGN
  DEV
  QA
}

model ProjectHealthSnapshot {
  id              String   @id @default(uuid())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  tenantId        String
  health          Float
  volatilityDelta Float?
  breakdown       Json     // Store the domain values AND primaryDriver
  snapshotDate    DateTime @default(now())
  
  @@index([projectId])
  @@index([tenantId, snapshotDate])
}
